---
import Base from '../../layouts/Base.astro';
---
<Base title="Contact — Iowa City High Bands">

<section class="page-hero">
  <div class="wrap">
    <div class="page-hero__inner">
      <div class="meta">Contact</div>
      <h1>Talk to a person.</h1>
      <p class="lede">Whether you're a prospective student, a current parent, an alum, or a member of the press — there's a real person at this address. Pick the right one and you'll hear back quickly.</p>
    </div>
  </div>
</section>

<section class="wrap">
  <div class="contact-grid">
    <div>
      <div class="contact-block">
        <h3>Directors</h3>
        <ul>
          <li>
            <span class="contact-block__role">Co-Director of Bands</span>
            <span>Mike Kowbel</span>
            <a href="mailto:kowbel.michael@iowacityschools.org">kowbel.michael@iowacityschools.org</a>
          </li>
          <li>
            <span class="contact-block__role">Co-Director of Bands</span>
            <span>Aaron Ottmar</span>
            <a href="mailto:ottmar.aaron@iowacityschools.org">ottmar.aaron@iowacityschools.org</a>
          </li>
        </ul>
      </div>

      <div class="contact-block">
        <h3>Band Associates of City High (BACH)</h3>
        <ul>
          <li>
            <span class="contact-block__role">General inbox</span>
            <a href="mailto:band.associates.chs@gmail.com">band.associates.chs@gmail.com</a>
          </li>
          <li>
            <span class="contact-block__role">President</span>
            <span>Jim Sherlock</span>
            <a href="mailto:jrsherlock@gmail.com">jrsherlock@gmail.com</a>
          </li>
        </ul>
      </div>

      <div class="contact-block">
        <h3>Where we are</h3>
        <ul>
          <li>
            <span class="contact-block__role">Band room</span>
            <span>Iowa City High School</span>
            <span>1900 Morningside Drive, Iowa City, IA 52245</span>
          </li>
          <li>
            <span class="contact-block__role">Performance venue</span>
            <span>Opstad Auditorium (on campus)</span>
          </li>
        </ul>
      </div>

      <div class="contact-block">
        <h3>Sister programs</h3>
        <ul>
          <li><a href="https://www.cityhighchoirs.com/">City High Choirs</a></li>
          <li><a href="https://cityhighmusic.jimdo.com/">City High Orchestras</a></li>
          <li><a href="https://sites.google.com/a/iowacityschools.org/city-high-school-music-department/">City High Music Office</a></li>
        </ul>
      </div>
    </div>

    <form class="contact-form" method="post" action="#" novalidate>
      <h2>Send us a note.</h2>
      <p class="contact-form__lede">Tell us who you are and we'll get it to the right person within a couple days.</p>

      <div class="field field--radios">
        <div class="meta">I'm a…</div>
        <div class="radio-row">
          <label class="radio-pill"><input type="radio" name="role" value="prospective" /> Prospective family</label>
          <label class="radio-pill"><input type="radio" name="role" value="current" /> Current family</label>
          <label class="radio-pill"><input type="radio" name="role" value="alum" /> Alum</label>
          <label class="radio-pill"><input type="radio" name="role" value="supporter" /> Supporter</label>
          <label class="radio-pill"><input type="radio" name="role" value="press" /> Press</label>
        </div>
      </div>

      <div class="field">
        <label for="name">Your name</label>
        <input id="name" name="name" type="text" autocomplete="name" />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" />
      </div>

      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message"></textarea>
      </div>

      <button class="btn btn-primary" type="submit">Send message</button>

      <p style="margin-top: 1.25rem; font-size: 0.85rem; color: var(--muted);">
        Form will route to the directors and BACH president once the contact endpoint is wired up.
      </p>
    </form>
  </div>
</section>

</Base>
