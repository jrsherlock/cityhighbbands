---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Iowa City High Bands — The School That Leads. Concert, marching, and jazz ensembles at Iowa City High School." } = Astro.props;
import '../styles/site.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="wrap site-header__inner">
      <a class="brand" href="/">
        <span>Iowa City High Bands</span>
        <small>The School That Leads</small>
      </a>
      <nav class="nav" aria-label="Primary">
        <a href="/program">The Program</a>
        <a href="/ensembles">Ensembles</a>
        <a href="/calendar">Calendar</a>
        <a href="/media">Media</a>
        <a href="/history">History</a>
        <a href="/support" class="nav-cta">Support</a>
      </nav>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="site-footer__grid">
        <div>
          <h4>Iowa City High Bands</h4>
          <p style="color: rgba(250,248,244,0.7); font-size: 0.9rem; max-width: 36ch;">1900 Morningside Drive, Iowa City, IA 52245.<br />Part of the Iowa City Community School District.</p>
        </div>
        <div>
          <h4>Directors</h4>
          <ul>
            <li><a href="mailto:kowbel.michael@iowacityschools.org">Mike Kowbel</a></li>
            <li><a href="mailto:ottmar.aaron@iowacityschools.org">Aaron Ottmar</a></li>
          </ul>
        </div>
        <div>
          <h4>Explore</h4>
          <ul>
            <li><a href="/ensembles">Ensembles</a></li>
            <li><a href="/calendar">Calendar</a></li>
            <li><a href="/history">History</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4>Music Department</h4>
          <ul>
            <li><a href="https://www.cityhighchoirs.com/">Choirs</a></li>
            <li><a href="https://cityhighmusic.jimdo.com/">Orchestras</a></li>
            <li><a href="https://sites.google.com/a/iowacityschools.org/city-high-school-music-department/">Music Office</a></li>
          </ul>
        </div>
      </div>
      <div class="site-footer__legal">
        <div>© {new Date().getFullYear()} Iowa City High Band Associates</div>
        <div>Site maintained by BACH</div>
      </div>
    </div>
  </footer>
</body>
</html>
